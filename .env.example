# Clerk (https://dashboard.clerk.com → API Keys). Enable Google + Facebook
# under "User & Authentication → Social Connections".
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxx
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxx

# Optional: where Clerk sends users for sign-in/up (defaults to a modal/redirect)
# NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
# NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# Cloudflare D1 is configured via wrangler.toml (binding "DB"), not env vars.
